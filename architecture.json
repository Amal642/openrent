{
  "project": {
    "name": "OpenRent Agent",
    "description": "Full-stack AI automation platform for OpenRent outreach with a client-facing conversation test lab",
    "type": "Monorepo",
    "branch": "main",
    "database": "SQLite (openrent.db) / Postgres",
    "root": "d:/openrent/openrent"
  },
  "techStack": {
    "backend": ["FastAPI", "SQLAlchemy", "Playwright", "OpenAI API", "Uvicorn", "python-dotenv"],
    "frontend": ["React 18.3", "Vite 5.4"],
    "testing": ["pytest"],
    "language": ["Python 3.x", "JavaScript / JSX"],
    "database": ["SQLite", "PostgreSQL"]
  },
  "layers": [
    {
      "id": "frontend",
      "label": "Frontend",
      "color": "#6366f1",
      "nodes": [
        {
          "id": "sim_lab_ui",
          "label": "Simulation Lab UI",
          "path": "frontend/simulation-lab/",
          "tech": "React 18 + Vite",
          "description": "Client/tester-facing UI for landlord conversation tests, message-style comparison, and advanced inspection",
          "components": [
            "InteractivePanel.jsx",
            "CompareDesignsPanel.jsx",
            "RunPanel.jsx",
            "SessionList.jsx",
            "TranscriptViewer.jsx",
            "EvaluationScorecard.jsx",
            "ConversationStatePanel.jsx",
            "EventTimeline.jsx",
            "PromptCompletionInspector.jsx",
            "RuntimeContextPanel.jsx",
            "ReplayViewer.jsx"
          ],
          "modes": ["test", "advanced"]
        },
        {
          "id": "command_center_ui",
          "label": "Command Center UI",
          "path": "frontend/openrent-command-center/",
          "tech": "React 18 + Vite",
          "description": "Operations dashboard for account and lead management",
          "components": ["App.jsx", "main.jsx"]
        }
      ]
    },
    {
      "id": "api",
      "label": "API Layer",
      "color": "#0ea5e9",
      "nodes": [
        {
          "id": "fastapi",
          "label": "FastAPI App",
          "path": "app/api/main.py",
          "tech": "FastAPI + Uvicorn",
          "description": "Main REST API with 40+ endpoints",
          "endpointGroups": [
            {
              "prefix": "/api/health",
              "routes": ["GET /api/health"]
            },
            {
              "prefix": "/api/accounts",
              "routes": ["GET", "POST", "PATCH", "DELETE", "POST /{id}/run", "POST /{id}/toggle"]
            },
            {
              "prefix": "/api/search-profiles",
              "routes": ["GET", "POST", "PATCH", "DELETE"]
            },
            {
              "prefix": "/api/leads",
              "routes": ["GET /api/leads", "GET /api/metrics", "GET /api/logs"]
            },
            {
              "prefix": "/simulation",
              "routes": [
                "POST /simulation/run",
                "GET /simulation/conversation-designs",
                "GET /simulation/scenarios",
                "POST /simulation/compare-designs",
                "POST /simulation/interactive/start",
                "GET /simulation/interactive/{session_id}",
                "POST /simulation/interactive/{session_id}/message",
                "GET /simulation/sessions",
                "GET /simulation/sessions/{session_id}",
                "GET /simulation/results/{session_id}"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "production",
      "label": "Production Automation",
      "color": "#10b981",
      "nodes": [
        {
          "id": "ai_module",
          "label": "AI Module",
          "path": "app/ai/",
          "description": "Prompt engine, personas, reply generation, stage tracking",
          "files": {
            "prompts.py": "SINGLE SOURCE OF TRUTH — _DESIGN_RULES dict, build_reply_prompt(), build_phone_extraction_prompt()",
            "personas.py": "Renter persona templates and normalization",
            "replies.py": "Reply generation and validation",
            "stages.py": "Conversation stage tracking (VIEWING_DISCUSSION, VIEWING_BOOKED, etc.)",
            "conversation_memory.py": "Conversation state and memory management",
            "extractors.py": "Data extraction from messages",
            "validators.py": "Prompt/reply validation"
          },
          "designRules": [
            "viewing_first_v1",
            "screening_first_v1",
            "confirmation_close_v1",
            "tenant_shares_first_v1",
            "landlord_preference_v1"
          ]
        },
        {
          "id": "db_module",
          "label": "Database Layer",
          "path": "app/db/",
          "description": "SQLAlchemy ORM, repository pattern, migrations",
          "files": {
            "models.py": "Account, SearchProfile ORM models",
            "repository.py": "40+ query functions — CRUD, leads, dashboard aggregation",
            "connection.py": "SQLAlchemy engine setup",
            "init_db.py": "Database initialization",
            "status.py": "Conversation status enums",
            "migrations/": "SQL migration files"
          }
        },
        {
          "id": "browser_module",
          "label": "Browser Automation",
          "path": "app/browser/",
          "description": "Playwright-based OpenRent browser automation",
          "files": {
            "launcher.py": "Playwright browser launch with proxy support",
            "auth.py": "OpenRent login automation",
            "selectors.py": "CSS selectors for OpenRent UI"
          }
        },
        {
          "id": "openrent_module",
          "label": "OpenRent Platform",
          "path": "app/openrent/",
          "description": "OpenRent-specific workflows — inbox, messaging, search",
          "files": {
            "inbox.py": "Inbox navigation and message retrieval",
            "messaging.py": "Send messages, reply to landlords",
            "landlords.py": "Landlord profile scraping",
            "listings.py": "Property listing operations",
            "search.py": "Property search"
          }
        },
        {
          "id": "workers_module",
          "label": "Workers & Jobs",
          "path": "app/workers/ + app/jobs/",
          "description": "Background task runners and scheduled jobs",
          "files": {
            "account_worker.py": "Background task runner for account operations",
            "process_replies.py": "Job: Process incoming landlord replies",
            "send_messages.py": "Job: Send outbound messages",
            "sync_crm.py": "Job: Sync to Zoho CRM"
          }
        },
        {
          "id": "integrations_module",
          "label": "Integrations",
          "path": "app/integrations/ + app/extraction/",
          "description": "External integrations and data extraction",
          "files": {
            "zoho.py": "Zoho CRM integration",
            "phone_extractor.py": "Phone number extraction from conversations"
          }
        }
      ]
    },
    {
      "id": "simulation",
      "label": "Simulation Lab",
      "color": "#f59e0b",
      "nodes": [
        {
          "id": "sim_engine",
          "label": "Simulation Engine",
          "path": "simulation/engine/",
          "description": "Core orchestration engine for deterministic conversation testing",
          "files": {
            "orchestrator.py": "SimulationOrchestrator — main runner, coordinates all components",
            "runner.py": "Run single/batch simulations",
            "session_manager.py": "Session lifecycle — generate replies, emit events, finalize",
            "event_bus.py": "Event emission and collection",
            "runtime_context.py": "Conversation context — metrics, memory, flags, entities",
            "deterministic.py": "Deterministic RNG seeding for reproducibility",
            "state_projection.py": "State reconstruction for replay"
          }
        },
        {
          "id": "sim_designs",
          "label": "Conversation Designs",
          "path": "simulation/conversation_designs.py",
          "description": "ConversationDesign dataclass — active design metadata, property-aware opening templates, persona construction, success/failure criteria",
          "activeDesigns": [
            "viewing_first_v1",
            "screening_first_v1",
            "confirmation_close_v1",
            "tenant_shares_first_v1",
            "landlord_preference_v1"
          ]
        },
        {
          "id": "sim_scenarios",
          "label": "Scenario Library",
          "path": "simulation/scenario_library.py + simulation/scenarios/generators.py",
          "description": "Static comparison scenarios and generated interactive/run scenarios with property and persona data",
          "scenarios": [
            "normal_viewing_offer",
            "screening_before_viewing",
            "phone_refusal_before_viewing",
            "asks_for_tenant_phone_early",
            "vague_landlord_reply",
            "viewing_confirmed_then_coordination",
            "outreach-screening-before-phone",
            "outreach-phone-request",
            "reply-after-landlord-question",
            "screening-before-phone"
          ]
        },
        {
          "id": "sim_actors",
          "label": "Actors",
          "path": "simulation/actors/",
          "description": "Pluggable actors for landlord role",
          "files": {
            "base.py": "BaseActor abstract interface",
            "landlord_actor.py": "Simulated landlord using scenario rules",
            "human_actor.py": "Human tester playing landlord",
            "simulated_actor.py": "LLM-based simulated landlord"
          }
        },
        {
          "id": "sim_policies",
          "label": "Policies",
          "path": "simulation/policies/",
          "description": "AI reply policies — pluggable strategy pattern",
          "files": {
            "production_policy.py": "ProductionPolicy — reads prompts.py _DESIGN_RULES, temperature=0.0",
            "aggressive_followup.py": "Aggressive escalation variant",
            "minimal_policy.py": "Minimal replies variant",
            "experimental/": "Experimental policy variants"
          }
        },
        {
          "id": "sim_evaluators",
          "label": "Evaluators",
          "path": "simulation/evaluators/",
          "description": "Evaluate conversation success/failure",
          "files": {
            "heuristic.py": "HeuristicEvaluator — scores viewing_progress, phone_capture, answer_quality, timing",
            "failure_types.py": "Failure type constants",
            "rubric.py": "Scoring rubrics",
            "llm_judge.py": "LLM-based evaluation (optional)"
          },
          "failureTypes": [
            "ASKED_PHONE_BEFORE_VIEWING",
            "FAILED_PHONE_CAPTURE",
            "FAILED_TO_MOVE_TOWARD_VIEWING"
          ]
        },
        {
          "id": "sim_state",
          "label": "Conversation State",
          "path": "simulation/conversation_state.py",
          "description": "Deterministic signal extraction from transcript — no LLM required",
          "signals": [
            "viewing_requested",
            "viewing_confirmed",
            "phone_captured",
            "screening_answered"
          ]
        },
        {
          "id": "sim_sessions",
          "label": "Sessions & Memory",
          "path": "simulation/sessions/ + simulation/memory/",
          "description": "Session persistence, transcript models, memory state. JSON run history is shared across trusted lab users.",
          "files": {
            "models.py": "SimulationSession, EvaluationResult",
            "store.py": "JSONSessionStore — persist sessions to JSON",
            "transcript.py": "Transcript Turn/Speaker models",
            "event_models.py": "Event dataclass"
          }
        },
        {
          "id": "sim_interactive",
          "label": "Interactive Mode",
          "path": "simulation/interactive.py",
          "description": "Human tester acts as landlord in real-time — max 25 turns"
        },
        {
          "id": "sim_compare",
          "label": "Design Comparison",
          "path": "simulation/compare.py",
          "description": "Run same scenario against multiple designs and produce comparison metrics"
        },
        {
          "id": "sim_observability",
          "label": "Observability",
          "path": "simulation/observability/ + simulation/replay/",
          "description": "Metrics collection, token tracking, event tracing, replay formatting",
          "files": {
            "metrics.py": "MetricsCollector — token usage, latency",
            "token_usage.py": "Track OpenAI token counts",
            "tracing.py": "Event timestamp generation",
            "formatter.py": "Format session for human readability",
            "timeline.py": "Event timeline rendering"
          }
        }
      ]
    },
    {
      "id": "external",
      "label": "External Services",
      "color": "#ef4444",
      "nodes": [
        {
          "id": "openai",
          "label": "OpenAI API",
          "description": "GPT model for reply generation",
          "envVar": "OPENAI_API_KEY, OPENAI_REPLY_MODEL"
        },
        {
          "id": "openrent_platform",
          "label": "OpenRent Platform",
          "description": "Rental platform — automated via Playwright browser"
        },
        {
          "id": "zoho_crm",
          "label": "Zoho CRM",
          "description": "CRM sync for leads and conversations"
        }
      ]
    }
  ],
  "dataFlows": [
    {
      "id": "interactive_session",
      "label": "Interactive Session Flow",
      "steps": [
        "Frontend POST /simulation/interactive/start",
        "simulation/interactive.py: start_interactive_session()",
        "simulation/scenario_library.py or generators.py (resolve property/persona scenario)",
        "simulation/conversation_designs.py (build_simulation_persona and render property-aware opener)",
        "simulation/engine/session_manager.py (emit initial tenant message)",
        "Frontend receives session_id",
        "Human tester replies → POST /simulation/interactive/{session_id}/message",
        "simulation/interactive.py: submit_interactive_message()",
        "simulation/policies/production_policy.py (get next AI message)",
        "simulation/evaluators/heuristic.py (evaluate progress)",
        "Frontend receives updated transcript, state, evaluation"
      ]
    },
    {
      "id": "reply_generation",
      "label": "Conversation Design → AI Reply",
      "steps": [
        "conversation_design_id (from UI or API)",
        "simulation/conversation_designs.py (get design metadata and property-aware opening template)",
        "app/ai/prompts.py: _DESIGN_RULES[design_id] (get rules)",
        "app/ai/prompts.py: build_reply_prompt() (compose prompt)",
        "simulation/policies/production_policy.py (call policy with persona and property context)",
        "OpenAI API (generate reply)"
      ]
    },
    {
      "id": "account_automation",
      "label": "Account Automation Flow",
      "steps": [
        "API POST /api/accounts/{id}/run",
        "app/workers/account_worker.py: run_one_account_by_id()",
        "Playwright browser launches",
        "app/browser/launcher.py + auth.py (login to OpenRent)",
        "app/openrent/inbox.py (fetch new messages)",
        "For each message: app/ai/prompts.py build_reply_prompt()",
        "OpenAI API (generate reply)",
        "app/openrent/messaging.py (send reply)",
        "app/db/repository.py (log conversation status)"
      ]
    },
    {
      "id": "design_comparison",
      "label": "Simulation Comparison",
      "steps": [
        "Frontend POST /simulation/compare-designs",
        "simulation/compare.py: compare_conversation_designs()",
        "For each design_id: resolve policy from design_id",
        "Run orchestrator with landlord actor",
        "Evaluate with HeuristicEvaluator",
        "Return array of results (one per design)"
      ]
    }
  ],
  "environment": {
    "DATABASE_URL": "SQLite or Postgres connection string",
    "OPENAI_API_KEY": "OpenAI API key",
    "OPENAI_REPLY_MODEL": "GPT model (default: gpt-4.1-mini)",
    "EMAIL": "OpenRent account email",
    "PASSWORD": "OpenRent account password",
    "HEADLESS": "Playwright headless mode (true/false)",
    "AI_AUTOSEND": "Auto-send generated replies",
    "SIMULATION_DEFAULT_TEMPERATURE": "AI temperature (default: 0.0 — deterministic)",
    "SIMULATION_MAX_FOLLOWUPS": "Max follow-up messages per simulation",
    "WORKER_TICK_SECONDS": "Worker check interval (default: 300s)",
    "PROXY_SERVER": "Optional browser proxy server",
    "PROXY_USERNAME": "Proxy username",
    "PROXY_PASSWORD": "Proxy password"
  },
  "keyPrinciples": [
    "AI reply behavior rules live ONLY in app/ai/prompts.py (_DESIGN_RULES)",
    "Conversation design metadata and property-aware opening templates live in simulation/conversation_designs.py",
    "Active designs are viewing_first, screening_first, confirmation_close, tenant_shares_first, and landlord_preference",
    "Simulation is deterministic — RNG seeding ensures reproducibility",
    "Conversation state analysis uses heuristics, not LLM (fast, cheap)",
    "ProductionPolicy uses temperature=0.0 for deterministic simulation",
    "Repository pattern isolates all database logic",
    "Event bus enables full session replay and advanced inspection"
  ]
}
