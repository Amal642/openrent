# Core app
DATABASE_URL=postgresql+asyncpg://user:password@localhost/openrent
OPENAI_API_KEY=sk-your-openai-key

# OpenRent account
EMAIL=your-openrent-email@example.com
PASSWORD=your-openrent-password
OPENRENT_EMAIL=your-openrent-email@example.com
OPENRENT_PASSWORD=your-openrent-password

# Browser runtime
HEADLESS=true
SLOW_MO=500
SESSION_FILE=session.json

# Proxy (optional)
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_URL=

# AI reply settings
OPENAI_REPLY_MODEL=gpt-4.1-mini
OPENAI_REPLY_TEMPERATURE=0.7

# Simulation lab
SIMULATION_DEFAULT_TEMPERATURE=0
SIMULATION_MAX_FOLLOWUPS=1
