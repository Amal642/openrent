DATABASE_URL=sqlite:///openrent.db
CRM_USERNAME=admin
CRM_PASSWORD_HASH=
CRM_AUTH_SECRET=
OPENAI_API_KEY=sk-...
OPENAI_REPLY_MODEL=gpt-4.1-mini
SIMULATION_DEFAULT_TEMPERATURE=0.0
SIMULATION_MAX_FOLLOWUPS=1

HEADLESS=true
SLOW_MO=500
PLAYWRIGHT_BLOCK_IMAGE_MEDIA=true
AI_AUTOSEND=false
WORKER_TICK_SECONDS=300
MAX_PARALLEL_WORKERS=2

SESSION_FILE=session.json

# Google Sheets lead export. Keep disabled until the read-only audit succeeds.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SHEET_PERSON=Becky
GOOGLE_SHEET_TAB=Becky
GOOGLE_SHEET_LOCATION=London
GOOGLE_SHEET_DIRECTION=South
# Local development: absolute path to the replacement service-account JSON.
GOOGLE_APPLICATION_CREDENTIALS=
# Production alternative: JSON credentials stored as a platform secret.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_DISPATCH_SECONDS=60
GOOGLE_SHEETS_MAX_ATTEMPTS=8

PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

EMAIL=
PASSWORD=
